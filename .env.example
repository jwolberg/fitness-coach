# Copy to `.env` and adjust. Docker Compose reads this file (see docker-compose.yml).
# Synthetic data only — never put real member/health data or production secrets here.

# --- Neo4j ---
# NEO4J_URI is for running the API outside Compose (host -> mapped port).
# Inside Compose the `api` service overrides it to bolt://neo4j:7687 (service name).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- LLM / embeddings ---
# NOTE: embeddings are OpenAI-only (project decision) — OPENAI_API_KEY is REQUIRED
# to run retrieval/generation. There is no local embedding fallback.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Embedding model + vector width (must match the Neo4j vector index).
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
