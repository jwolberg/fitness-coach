# Copy to `.env` and adjust. Docker Compose reads this file (see docker-compose.yml).
# Synthetic data only — never put real member/health data or production secrets here.

# --- Neo4j ---
# NEO4J_URI is for running the API outside Compose (host -> mapped port).
# Inside Compose the `api` service overrides it to bolt://neo4j:7687 (service name).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- LLM / embeddings (provider-agnostic; used from Phase 2/3) ---
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
